// 1. Database Connection 
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 2. Roles (User lge types)
enum UserRole {
  ADMIN       // Company Admin
  MANAGER
  TECHNICIAN
  OCCUPANT
}

// 3. Tenant (Company / Organization)
model Tenant {
  id          String   @id @default(uuid())
  name        String
  
  // මෙන්න අපේ අලුත් Join Code එක 🔑
  // මේකෙන් තමයි අලුත් Technician කෙනෙක්ට කොම්පැණිය හොයාගන්න ලේසි වෙන්නේ.
  joinCode    String   @unique @default(cuid()) 
  
  domain      String?  @unique // e.g., alpha.fms.com
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  assets      Asset[]
  workOrders  WorkOrder[]

  @@index([createdAt])
}

// 4. Users table
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   
  firstName   String
  lastName    String
  role        UserRole @default(OCCUPANT)
  
  // Link to Tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation for Work Orders assigned to this user
  assignedWorkOrders WorkOrder[] @relation("AssignedWorkOrders")

  @@index([tenantId])
  @@index([role])
  @@index([createdAt])
}

// 5. Asset Status
enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

// 6. Assets (Inventory)
model Asset {
  id          String      @id @default(uuid())
  name        String
  category    String
  serialNo    String?
  status      AssetStatus @default(ACTIVE)

  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  workOrders  WorkOrder[]

  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@unique([tenantId, serialNo])
}

// 7. Work Order Status
enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

// 8. Work Order Priority
enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// 9. Work Orders 
model WorkOrder {
  id              String             @id @default(uuid())
  title           String
  description     String?
  status          WorkOrderStatus    @default(OPEN)
  priority        WorkOrderPriority  @default(MEDIUM)

  // Link to Asset
  assetId         String
  asset           Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Link to Tenant
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Link to Assigned Technician
  assignedToId    String?            
  assignedTo      User?              @relation("AssignedWorkOrders", fields: [assignedToId], references: [id])

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([tenantId])
  @@index([assetId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([assignedToId])
}