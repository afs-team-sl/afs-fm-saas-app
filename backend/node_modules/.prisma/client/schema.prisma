// 1. Database Connection 
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 2. Roles (User lge types)
enum UserRole {
  ADMIN // Company Admin
  MANAGER
  TECHNICIAN
  OCCUPANT
}

// 3. Tenant (Company / Organization)
model Tenant {
  id   String @id @default(uuid())
  name String

  // මෙන්න අපේ අලුත් Join Code එක 🔑
  // මේකෙන් තමයි අලුත් Technician කෙනෙක්ට කොම්පැණිය හොයාගන්න ලේසි වෙන්නේ.
  joinCode String @unique @default(cuid())

  domain    String?  @unique // e.g., alpha.fms.com
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users            User[]
  assets           Asset[]
  workOrders       WorkOrder[]
  parts            Part[]
  maintenancePlans MaintenancePlan[]
  buildings        Building[]

  @@index([createdAt])
}

// 4. Users table
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(OCCUPANT)

  // Link to Tenant
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation for Work Orders assigned to this user
  assignedWorkOrders WorkOrder[] @relation("AssignedWorkOrders")

  // Relation for Notifications
  notifications Notification[]

  @@index([tenantId])
  @@index([role])
  @@index([createdAt])
}

// 5. Asset Status
enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

// 6. Assets (Inventory)
model Asset {
  id       String      @id @default(uuid())
  name     String
  category String // Used for 'Type' in the UI
  serialNo String?
  status   AssetStatus @default(ACTIVE)

  // Advanced HVAC/Mechanical Fields
  site         String?
  location     String?
  customId     String?
  assetNumber  String?
  manufacturer String?
  modelNumber  String?
  installYear  Int?
  filterSize   String?
  beltSize     String?
  notes        String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Link to Room (Space & Facility Hierarchy)
  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrders       WorkOrder[]
  maintenancePlans MaintenancePlan[]

  @@unique([tenantId, serialNo])
  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([roomId])
}

// 7. Maintenance Frequency
enum MaintenanceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// 8. Work Order Status
enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

// 8. Work Order Priority
enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// 9. Work Orders 
model WorkOrder {
  id          String            @id @default(uuid())
  title       String
  description String?
  status      WorkOrderStatus   @default(OPEN)
  priority    WorkOrderPriority @default(MEDIUM)

  // Link to Asset
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Link to Tenant
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Link to Assigned Technician
  assignedToId String?
  assignedTo   User?   @relation("AssignedWorkOrders", fields: [assignedToId], references: [id])

  // Completion Note (Written by Technician)
  completionNote String?

  // Parts used in this work order
  parts WorkOrderPart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([assetId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([assignedToId])
}

// 10. Parts (Inventory & Spare Parts)
model Part {
  id         String @id @default(uuid())
  name       String
  partNumber String
  stockLevel Int    @default(0)
  minStock   Int    @default(10)
  unitPrice  Float  @default(0.0)

  // Link to Tenant
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Parts used in work orders
  workOrderParts WorkOrderPart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, partNumber])
  @@index([tenantId])
  @@index([stockLevel])
}

// 11. Work Order Parts (Junction table for materials used)
model WorkOrderPart {
  id       String @id @default(uuid())
  quantity Int

  // Link to Work Order
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  // Link to Part
  partId String
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([partId])
}

// 12. Maintenance Plans (Preventive Maintenance Scheduler)
model MaintenancePlan {
  id              String               @id @default(uuid())
  title           String
  description     String?
  frequency       MaintenanceFrequency
  nextDueDate     DateTime
  lastGeneratedAt DateTime?

  // Link to Asset
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Link to Tenant
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([assetId])
  @@index([nextDueDate])
  @@index([frequency])
}

// 13. Building (Space & Facility Hierarchy)
model Building {
  id      String  @id @default(uuid())
  name    String
  address String?

  // Link to Tenant
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  floors Floor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// 14. Floor (Space & Facility Hierarchy)
model Floor {
  id     String @id @default(uuid())
  number String // e.g., "Level 1", "Ground Floor", "Basement"

  // Link to Building
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  // Relations
  rooms Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
}

// 15. Room (Space & Facility Hierarchy)
model Room {
  id   String @id @default(uuid())
  name String // e.g., "Server Room", "Office 101", "Conference Room A"

  // Link to Floor
  floorId String
  floor   Floor  @relation(fields: [floorId], references: [id], onDelete: Cascade)

  // Relations
  assets Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([floorId])
}

// 16. Global Notification Type
enum NotificationType {
  INFO
  WARNING
  CRITICAL
  MAINTENANCE
}

// 17. Global Notifications (Super Admin Broadcasts)
model GlobalNotification {
  id       String           @id @default(uuid())
  message  String
  type     NotificationType @default(INFO)
  isActive Boolean          @default(true)

  createdAt DateTime  @default(now())
  expiresAt DateTime? // Optional expiration

  @@index([isActive])
  @@index([createdAt])
}

// 18. User Notification Type
enum UserNotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

// 19. User Notifications (Per-user or tenant-specific)
model Notification {
  id      String               @id @default(uuid())
  message String
  type    UserNotificationType @default(INFO)
  isRead  Boolean              @default(false)

  // Link to User (who receives the notification)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional: Tenant-specific notifications (null means global)
  tenantId String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([tenantId])
  @@index([createdAt])
}
