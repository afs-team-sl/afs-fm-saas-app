# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string for Prisma
DATABASE_URL='postgresql://admins:db-fms-dev6%25681367jHJDHQ(7@db-fms-dev.postgres.database.azure.com:5432/postgres?sslmode=require'

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Secret key for JWT token signing - CHANGE THIS IN PRODUCTION!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=MY_SECRET_KEY_123

# JWT token expiration time (e.g., '1d', '7d', '24h')
JWT_EXPIRES_IN=1d

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port for the NestJS server (Azure will override this with process.env.PORT)
PORT=3000

# Allowed CORS origins (comma-separated for multiple origins)
# In production, set this to your frontend URL
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# SUPER ADMIN / SYSTEM TENANT
# =============================================================================
# Super tenant ID for the system administrator organization
SUPER_TENANT_ID=05642b69-8f04-44d0-b74c-27c9db4b4969

# System super user ID (used for seeding/administrative tasks)
SYSTEM_SUPER_USER_ID=2930b04c-4b14-4540-a6fc-002093679b8b