# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string for Prisma
DATABASE_URL=postgresql://admins:db-fms-dev6%25681367jHJDHQ(7@db-fms-dev.postgres.database.azure.com:5432/postgres?sslmode=require

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Secret key for JWT token signing - CHANGE THIS IN PRODUCTION!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=MY_SECRET_KEY_123

# JWT token expiration time (e.g., '1d', '7d', '24h')
JWT_EXPIRES_IN=1d

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Port for the NestJS server (Azure will override this with process.env.PORT)
PORT=80

# Allowed CORS origins (comma-separated for multiple origins)
# For Docker development, include http://localhost and http://localhost:5173
# In production, set this to your frontend URL (e.g., https://your-domain.com)
CORS_ORIGIN=http://localhost,http://localhost:5173,http://localhost:3000,https://blue-tree-021d4c00f.1.azurestaticapps.net,https://afsnexsus.agilefacilities.com

# =============================================================================
# SUPER ADMIN / SYSTEM TENANT
# =============================================================================
# Super tenant ID for the system administrator organization
SUPER_TENANT_ID=05642b69-8f04-44d0-b74c-27c9db4b4969

# System super user ID (used for seeding/administrative tasks)
SYSTEM_SUPER_USER_ID=2930b04c-4b14-4540-a6fc-002093679b8b

# =============================================================================
# AZURE BLOB STORAGE CONFIGURATION
# =============================================================================
# Azure Storage Account connection string for file uploads
# Get this from: Azure Portal → Storage Account (blobfmsdev) → Access Keys → Connection string
# Format: DefaultEndpointsProtocol=https;AccountName=blobfmsdev;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONNECTION_STRING=https://blobfmsdev.blob.core.windows.net/blob
